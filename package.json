{
  "name": "aeo-fpa-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "python3 src/04_api_server.py",
    "start:app": "concurrently -k -n api,web -c blue,cyan \"python3 src/04_api_server.py\" \"vite\"",
    "gen:static": "python3 scripts/export_static_demo.py",
    "build": "vite build",
    "postbuild": "node -e \"const fs=require('fs');const p='dist/index.html';if(fs.existsSync(p))fs.copyFileSync(p,'dist/404.html');\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.5"
  }
}
